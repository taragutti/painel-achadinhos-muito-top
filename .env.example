# PostgreSQL
DATABASE_URL="postgresql://example_user:example_password@localhost:5432/achadinhos_example?schema=public"
APP_URL="http://localhost:3000"

# Product importing and owned image storage
SHOPEE_APP_ID="example_shopee_app_id"
SHOPEE_APP_SECRET="example_shopee_app_secret"
SHOPEE_AFFILIATE_ID="example_shopee_affiliate_id"
SHOPEE_API_BASE_URL="https://open-api.affiliate.shopee.com.br/graphql"
PRODUCT_IMPORT_TIMEOUT_MS="8000"
PRODUCT_IMPORT_CACHE_SECONDS="300"
PRODUCT_IMAGE_MAX_BYTES="5242880"

# Single administrator authentication
ADMIN_EMAIL="admin@example.invalid"
ADMIN_NAME="Administrador"
ADMIN_INITIAL_PASSWORD="replace_only_when_running_admin_script"
SESSION_TTL_HOURS="8"
LOGIN_MAX_ATTEMPTS="5"
LOGIN_WINDOW_MINUTES="15"
LOGIN_BLOCK_MINUTES="15"

# Safe defaults. Real delivery requires both PROVIDER_MODE and SEND_LIVE=true.
PROVIDER_MODE="mock"
SEND_LIVE="false"
MOCK_PROVIDERS="true"
DEMO_MODE="true"
MOCK_PROVIDER_BEHAVIOR="SUCCESS"
TELEGRAM_ENABLED="false"
WHATSAPP_ENABLED="false"
APP_ENCRYPTION_KEY="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
WORKER_POLL_INTERVAL_MS="5000"
DELIVERY_MAX_ATTEMPTS="3"
QUEUE_LOCK_LEASE_SECONDS="120"

# Protected observability endpoints (replace in every environment)
APP_HEALTH_TOKEN="replace_with_random_health_token"
WORKER_HEALTH_TOKEN="replace_with_different_random_health_token"
WORKER_API_URL="https://worker.example.invalid"
WORKER_API_TOKEN="replace_with_random_worker_control_token"
WORKER_HEALTH_HOST="0.0.0.0"
WORKER_HEALTH_PORT="9464"

# Telegram
TELEGRAM_BOT_TOKEN="replace_with_test_token"
TELEGRAM_GROUP_ID="replace_with_test_group_id"
TELEGRAM_GROUP_NAME="Grupo fictício"

# WhatsApp worker (session directory must remain outside Git)
WHATSAPP_SESSION_DIR="../../var/whatsapp-session"
WHATSAPP_ALLOWED_GROUP_ID="000000000000000000@g.us"
